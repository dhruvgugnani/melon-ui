# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Build Output ────────────────────────────────────────────────────────────
.next/
apps/web/.next/
/out/
/build/
/dist/
*.tsbuildinfo
next-env.d.ts

# ─── Testing & Coverage ──────────────────────────────────────────────────────
/coverage/
# Playwright screenshots & traces
playwright-*.png
playwright-*.jpg
playwright-report/
test-results/

# ─── Development Logs ────────────────────────────────────────────────────────
*.log
*.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-live.log
dev-live.err.log
start-live.log
start-live.err.log
dev-server*.log

# ─── Graphify (code-graph tool) ──────────────────────────────────────────────
graphify-out/
.graphifyignore
.graphify_*

# ─── Codex / AI Dev Tools ────────────────────────────────────────────────────
.codex/

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env*

# ─── Deployment ──────────────────────────────────────────────────────────────
.vercel

# ─── CLI build output ────────────────────────────────────────────────────────
cli/dist/
cli/node_modules/
